PROJECT_NAME           = "@DOXYGEN_PROJECT_NAME@"
PROJECT_VERSION        = "@DOXYGEN_PROJECT_VERSION@"
PROJECT_BRIEF          = "Modular spellchecker built around BK-Trees"

OUTPUT_DIRECTORY       = @DOXYGEN_OUTPUT_DIR@
INPUT                  = @DOXYGEN_INPUT_DIR@
RECURSIVE              = YES

USE_MDFILE_AS_MAINPAGE = frontpage.md
MARKDOWN_SUPPORT       = YES
FILE_PATTERNS          = *.h *.hpp *.cpp *.md

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES

GENERATE_HTML          = YES
GENERATE_LATEX         = NO

HTML_OUTPUT            = html
HTML_COLORSTYLE_HUE    = 220
HTML_COLORSTYLE_SAT    = 100
HTML_COLORSTYLE_GAMMA  = 80

QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
